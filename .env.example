# ── App ──────────────────────────────────────
APP_ENV=development
APP_PORT=8000

# ── MariaDB ──────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=logfixer
DB_USER=logfixer
DB_PASSWORD=logfixer1234

# ── Qdrant ───────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── Elasticsearch ────────────────────────────
ES_HOST=http://localhost:9200

# ── OpenAI ─────────────────────────
OPENAI_API_KEY=sk-...

# ── Slack ────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C...

# ── LC (LogCollector) ────────────────────
LC_BASE_URL=http://localhost:8080
LC_API_KEY=

# ── SSH (Agent) ────────────────────────
SSH_DEFAULT_USER=ubuntu
SSH_DEFAULT_KEY_PATH=/home/ubuntu/.ssh/id_rsa